---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import FAQ from '../../components/FAQ.astro';

const faqs = [
  {
    q: 'Can Altered Air install a custom walk-in cooler or freezer for my restaurant?',
    a: 'Yes. We design and install custom walk-in coolers and freezers for restaurants, commercial kitchens, catering operations, and food retail. We assess your space, determine the right capacity and configuration, source the equipment, and install everything to manufacturer and code specifications. Call <a href="tel:+17605941125">(760) 594-1125</a> for a free consultation and quote.'
  },
  {
    q: 'What types of commercial refrigeration systems do you install?',
    a: 'We install walk-in coolers, walk-in freezers, reach-in refrigerators and freezers, deli and display cases, ice machines, wine refrigeration systems, VRF (variable refrigerant flow) systems, Sub-Zero and premium brand units, beverage coolers, and cold storage rooms for warehouses and food processing.'
  },
  {
    q: 'How long does a commercial refrigeration installation take?',
    a: 'Timeline depends heavily on the size and complexity of the system. A reach-in refrigerator installation can be completed in a few hours. A custom walk-in cooler with custom panels, flooring, and refrigeration equipment typically takes 2–5 days. Large cold storage or multi-zone systems may take longer. We will give you a realistic project timeline before starting.'
  },
  {
    q: 'Do you pull permits for refrigeration installations?',
    a: 'When permits are required by local code, we coordinate with the appropriate municipality. We are familiar with permitting requirements in Buckeye, Goodyear, Avondale, Tolleson, and other West Valley cities. Ask us about permitting when you request your installation quote.'
  },
  {
    q: 'Can you install refrigeration systems in new construction or tenant improvements?',
    a: 'Yes. We work with general contractors, restaurant developers, and commercial property owners on new construction and tenant improvement projects. We can coordinate with other trades and work from construction drawings to install refrigeration systems at the right phase of your project.'
  }
];
---

<Layout
  title="Commercial Refrigeration Installation in Buckeye, AZ | Altered Air | (760) 594-1125"
  description="Walk-in cooler and freezer installation, VRF systems, ice machines, deli cases, and commercial refrigeration in Buckeye, AZ. Free quotes from Altered Air. Call (760) 594-1125."
  canonical="/services/refrigeration-installation"
>
  <section class="page-hero">
    <div class="container">
      <p class="breadcrumb"><a href="/">Home</a> → Services → Refrigeration Installation</p>
      <h1>Commercial Refrigeration Installation — Buckeye, AZ</h1>
      <p>
        From a single reach-in cooler to a full multi-zone walk-in cold storage system, Altered Air
        handles commercial refrigeration installation for restaurants, food retailers, warehouses, and
        businesses throughout the West Valley. John Rigo brings the expertise to get your system
        designed, installed, and running right the first time.
      </p>
      <a href="tel:+17605941125" class="phone-link">&#128222; Free Quote: (760) 594-1125</a>
    </div>
  </section>

  <section>
    <div class="container">
      <h2>Refrigeration Systems We Install</h2>
      <p style="max-width:680px; color:var(--gray-600); margin-bottom:2rem;">
        Altered Air installs commercial and specialty refrigeration systems for a wide range of business
        types and applications across the West Valley.
      </p>
      <div class="service-list">
        <div class="service-item">
          <h3>Walk-in Coolers</h3>
          <p>Custom-sized walk-in coolers for restaurants, grocery stores, food retail, and cold storage. We source and install panels, floors, doors, and all refrigeration equipment.</p>
        </div>
        <div class="service-item">
          <h3>Walk-in Freezers</h3>
          <p>Walk-in freezers for food service, food processing, and cold storage applications. We design to your temperature, humidity, and capacity requirements.</p>
        </div>
        <div class="service-item">
          <h3>VRF Systems</h3>
          <p>Variable Refrigerant Flow systems for large commercial buildings requiring flexible, zone-controlled refrigeration and cooling across multiple areas.</p>
        </div>
        <div class="service-item">
          <h3>Sub-Zero &amp; Premium Units</h3>
          <p>Installation of Sub-Zero, True, Hoshizaki, and other premium refrigeration brands for upscale restaurants, country clubs, resorts, and high-end commercial kitchens.</p>
        </div>
        <div class="service-item">
          <h3>Wine Refrigeration Systems</h3>
          <p>Climate-controlled wine storage for restaurants, wine bars, retail wine shops, and private cellars. Proper temperature and humidity control to protect valuable inventory.</p>
        </div>
        <div class="service-item">
          <h3>Ice Machine Installation</h3>
          <p>Commercial ice machine installation and connection for restaurants, bars, hotels, hospitals, and food processing. All major brands and ice types.</p>
        </div>
        <div class="service-item">
          <h3>Deli Cases &amp; Display Refrigerators</h3>
          <p>Service deli cases, open-air merchandisers, and glass-door display refrigerators for grocery, convenience, and food retail operations.</p>
        </div>
        <div class="service-item">
          <h3>Reach-in Refrigerators &amp; Freezers</h3>
          <p>Commercial reach-in refrigerator and freezer installation for restaurant kitchens, food prep areas, medical facilities, and laboratory environments.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray">
    <div class="container">
      <div class="content-two-col">
        <div>
          <h2>Our Installation Approach</h2>
          <p>
            Refrigeration installation is not just about connecting equipment — it requires proper
            refrigerant line sizing, correct electrical connections, proper airflow clearances, and
            careful commissioning to ensure the system performs to spec from day one.
          </p>
          <p>
            John Rigo approaches every installation with the care and precision of someone who will
            also be responsible for servicing the equipment after it is installed. We do it right the
            first time because we do not want to come back to fix a shortcut.
          </p>
          <ul class="feature-list" style="margin-top:1rem;">
            <li>Site assessment and load calculation before equipment selection</li>
            <li>Proper refrigerant line sizing and routing</li>
            <li>All electrical work to code with correct circuit protection</li>
            <li>Manufacturer-specified refrigerant charge and system commissioning</li>
            <li>Full temperature testing before handover</li>
            <li>Documentation of all specifications and warranty registration</li>
          </ul>
        </div>
        <div>
          <div class="highlight-box">
            <h3>Planning a New Commercial Kitchen or Cold Storage?</h3>
            <p>
              Talk to John early in your project — refrigeration requires coordinated planning with
              electrical, plumbing, and construction. Get your consultation before you break ground.
            </p>
            <a href="tel:+17605941125" class="phone">(760) 594-1125</a>
            <a href="/contact" class="btn-primary" style="margin-top:0.5rem;">Request a Consultation</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2>Serving West Valley Businesses</h2>
      <p style="max-width:760px; color:var(--gray-600);">
        We install commercial refrigeration systems throughout the West Valley — from new restaurant
        build-outs in <a href="/locations/goodyear-az">Goodyear</a> and <a href="/locations/queen-creek-az">Queen Creek</a>
        to food processing cold storage in <a href="/locations/tolleson-az">Tolleson's industrial corridor</a>.
        Also see our <a href="/services/refrigeration-repair">refrigeration repair</a>,
        <a href="/services/refrigeration-design">refrigeration design</a>, and
        <a href="/services/refrigeration-maintenance">refrigeration maintenance</a> services.
      </p>
    </div>
  </section>

  <CTA
    heading="Get a Free Refrigeration Installation Quote"
    subtext="Commercial refrigeration installation for restaurants, food retailers, warehouses, and food processors throughout Buckeye, AZ and the West Valley. Call John Rigo today."
  />

  <FAQ faqs={faqs} heading="Refrigeration Installation FAQs" />
</Layout>
