---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import FAQ from '../../components/FAQ.astro';

const faqs = [
  {
    q: 'How quickly can Altered Air respond to an AC repair call in Buckeye?',
    a: 'We prioritize same-day service for AC repairs throughout Buckeye and the West Valley. During peak summer months, we dispatch as quickly as possible — often within a few hours. For emergencies where there is no AC in extreme heat, call <a href="tel:+17605941125">(760) 594-1125</a> and let us know it is urgent.'
  },
  {
    q: 'What are the most common AC problems you repair?',
    a: 'The most common issues we see are refrigerant leaks, capacitor failures, dirty or frozen evaporator coils, failed compressors, faulty thermostats, and clogged condensate drain lines. Many of these can be diagnosed and repaired in a single visit.'
  },
  {
    q: 'How much does AC repair cost in Buckeye, AZ?',
    a: 'Repair costs depend on the problem. A capacitor replacement is relatively inexpensive, while a compressor replacement costs significantly more. We always provide an upfront estimate before performing any work — no surprise charges. Call <a href="tel:+17605941125">(760) 594-1125</a> for a diagnostic appointment.'
  },
  {
    q: 'Should I repair or replace my AC unit?',
    a: 'As a general rule, if your unit is over 10–12 years old and the repair cost exceeds 50% of a new system, replacement often makes more financial sense. John Rigo will give you an honest recommendation — we are not in the business of recommending replacements you do not need, or repairs that will not hold up.'
  },
  {
    q: 'Do you repair all AC brands?',
    a: 'Yes. We work on all major brands including Carrier, Trane, Lennox, Rheem, Goodman, Bryant, York, American Standard, Daikin, Mitsubishi, LG, and more. If it moves air or refrigerant, we can service it.'
  }
];
---

<Layout
  title="AC Repair in Buckeye, AZ — Same-Day Service | Altered Air | (760) 594-1125"
  description="Same-day AC repair in Buckeye, AZ and across the West Valley. John Rigo at Altered Air fixes compressors, coils, capacitors, refrigerant leaks, and more. Call (760) 594-1125."
  canonical="/services/ac-repair"
>
  <!-- Emergency Banner -->
  <div class="emergency-banner">
    <div class="container">
      <strong>&#128680; No AC in 115°F heat is a health emergency.</strong>
      Altered Air offers 24/7 emergency service. <a href="tel:+17605941125">Call now: (760) 594-1125</a>
    </div>
  </div>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <p class="breadcrumb"><a href="/">Home</a> → <a href="/services/ac-repair">Services</a> → AC Repair</p>
      <h1>AC Repair in Buckeye, AZ — Same-Day Service</h1>
      <p>
        When your air conditioner breaks down in a West Valley summer, every hour matters. Altered Air
        provides fast, reliable AC repair throughout Buckeye, AZ and surrounding communities — with same-day
        availability and 24/7 emergency response. Owner John Rigo handles every job personally.
      </p>
      <a href="tel:+17605941125" class="phone-link">&#128222; Call (760) 594-1125</a>
    </div>
  </section>

  <!-- Why urgency matters -->
  <section>
    <div class="container">
      <div class="urgency-box">
        <h3>&#128680; Arizona Heat Does Not Wait — Neither Should You</h3>
        <p>
          Buckeye and the West Valley regularly record temperatures above 110°F, with peak summer days
          pushing 115°F or higher. The Maricopa County Department of Public Health reports more heat-related
          deaths here than anywhere else in the country. A broken air conditioner in these conditions is not
          just uncomfortable — it is a genuine health emergency. Altered Air offers
          <a href="/services/emergency-repair">24-hour emergency AC repair</a> so you are never left
          without cooling when it matters most.
        </p>
      </div>

      <div class="content-two-col" style="margin-top: 3rem;">
        <div>
          <h2>Signs Your AC Needs Repair Right Now</h2>
          <p>
            Catching an AC problem early can mean the difference between a minor repair and a full system
            replacement. Watch for these warning signs and call Altered Air as soon as you notice them —
            especially during summer months when systems work hardest.
          </p>
          <ul class="feature-list">
            <li>Your home is not reaching the thermostat set temperature</li>
            <li>Weak or warm airflow from vents</li>
            <li>Unusual noises — grinding, squealing, banging, or clicking</li>
            <li>Ice forming on the refrigerant lines or evaporator coil</li>
            <li>Water pooling around the indoor unit</li>
            <li>Sudden spike in your electricity bill without increased usage</li>
            <li>System short-cycles — turning on and off repeatedly</li>
            <li>Refrigerant (freon) smell or visible leak around the outdoor unit</li>
            <li>System is over 10 years old and struggling in peak heat</li>
          </ul>
        </div>
        <div>
          <div class="highlight-box">
            <h3>Same-Day AC Repair in Buckeye</h3>
            <p>
              Don't wait until your system completely fails. Call Altered Air at the first sign of trouble
              for fast diagnostics and same-day repair.
            </p>
            <a href="tel:+17605941125" class="phone">(760) 594-1125</a>
            <a href="tel:+17605941125" class="btn-primary" style="margin-top:0.5rem;">Call Now</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Repair Services -->
  <section class="bg-gray">
    <div class="container">
      <h2>AC Repair Services We Provide</h2>
      <p style="max-width:680px; color:var(--gray-600); margin-bottom:2rem;">
        Altered Air handles the full range of residential and commercial AC repairs. John Rigo diagnoses
        problems accurately the first time — and gives you an honest recommendation on whether to repair
        or replace.
      </p>

      <div class="service-list">
        <div class="service-item">
          <h3>Emergency 24-Hour AC Repair</h3>
          <p>No AC on a 115°F day is an emergency. We respond around the clock for urgent situations in Buckeye and across the West Valley.</p>
        </div>
        <div class="service-item">
          <h3>Compressor Repair &amp; Replacement</h3>
          <p>The compressor is the heart of your AC system. We diagnose compressor failures accurately and provide honest guidance on repair vs. replacement.</p>
        </div>
        <div class="service-item">
          <h3>Condenser Coil Repair</h3>
          <p>Dirty or damaged condenser coils cause your system to overheat and fail. We clean, repair, and replace condenser coils for full system efficiency.</p>
        </div>
        <div class="service-item">
          <h3>Evaporator Coil Repair</h3>
          <p>A frozen or leaking evaporator coil prevents your system from cooling properly. We restore full coil function and correct the underlying cause.</p>
        </div>
        <div class="service-item">
          <h3>Capacitor Replacement</h3>
          <p>Capacitors are a common failure point in the Arizona heat. A bad start or run capacitor will prevent your AC from starting. We carry capacitors for most major brands on the truck.</p>
        </div>
        <div class="service-item">
          <h3>AC Refrigerant Leak Detection &amp; Repair</h3>
          <p>Low refrigerant causes your AC to blow warm air and run constantly. We locate leaks, perform EPA-compliant repairs, and recharge your system to factory specifications.</p>
        </div>
        <div class="service-item">
          <h3>Air Handler Repair</h3>
          <p>The air handler moves conditioned air through your ductwork. We repair and replace faulty blower motors, fan blades, and air handler components.</p>
        </div>
        <div class="service-item">
          <h3>Thermostat Repair &amp; Replacement</h3>
          <p>A malfunctioning thermostat causes erratic AC behavior. We diagnose thermostat issues and install smart, programmable thermostats that reduce energy waste.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section>
    <div class="container">
      <h2>Our AC Repair Process</h2>
      <p style="max-width:660px; color:var(--gray-600); margin-bottom:2.5rem;">
        We believe in transparency at every step. Here is exactly what to expect when you call Altered Air
        for AC repair in Buckeye or anywhere in the West Valley.
      </p>
      <div class="steps-container" style="max-width:760px;">
        <div class="step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>Call or Request Online</h3>
            <p>Call <a href="tel:+17605941125">(760) 594-1125</a> or use our contact form. Tell us what is happening and we will schedule same-day service whenever possible.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3>On-Site Diagnosis</h3>
            <p>John arrives on time, performs a thorough diagnostic, and explains exactly what he finds — in plain language, not HVAC jargon.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3>Upfront Estimate</h3>
            <p>Before any work begins, you get a written estimate. No hidden fees, no upsells you did not ask for. You approve the work before we start.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">4</div>
          <div class="step-content">
            <h3>Repair &amp; Test</h3>
            <p>We complete the repair, test the system fully, and verify it is cooling to spec. We do not leave until we know the job is done right.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">5</div>
          <div class="step-content">
            <h3>Follow-Up</h3>
            <p>We stand behind our work. If something is not right after a repair, call us and we will make it right.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Brands & Locations -->
  <section class="bg-gray">
    <div class="container">
      <div class="content-two-col">
        <div>
          <h2>Brands We Service</h2>
          <p>
            Altered Air is experienced with all major residential and commercial HVAC brands.
            Whether you have a 20-year-old Carrier or a brand-new Daikin mini-split, we have the
            knowledge and parts to get it running.
          </p>
          <ul class="feature-list">
            <li>Carrier &amp; Bryant</li>
            <li>Trane &amp; American Standard</li>
            <li>Lennox</li>
            <li>Rheem &amp; Ruud</li>
            <li>Goodman &amp; Amana</li>
            <li>Daikin</li>
            <li>Mitsubishi Electric</li>
            <li>LG &amp; Samsung</li>
            <li>York &amp; Coleman</li>
            <li>And all other major brands</li>
          </ul>
        </div>
        <div>
          <h2>Areas We Serve</h2>
          <p>AC repair is available throughout the West Valley. Our primary service cities include:</p>
          <div class="location-grid" style="margin-top:1rem;">
            <div class="location-tag"><a href="/locations/buckeye-az">Buckeye</a></div>
            <div class="location-tag"><a href="/locations/goodyear-az">Goodyear</a></div>
            <div class="location-tag"><a href="/locations/queen-creek-az">Queen Creek</a></div>
            <div class="location-tag"><a href="/locations/surprise-az">Surprise</a></div>
            <div class="location-tag"><a href="/locations/avondale-az">Avondale</a></div>
            <div class="location-tag"><a href="/locations/litchfield-park-az">Litchfield Park</a></div>
            <div class="location-tag"><a href="/locations/tolleson-az">Tolleson</a></div>
            <div class="location-tag"><a href="/locations/laveen-az">Laveen</a></div>
            <div class="location-tag"><a href="/locations/peoria-az">Peoria</a></div>
          </div>
          <p style="margin-top:1rem; font-size:0.9rem; color:var(--gray-600);">
            Also serving: <a href="/services/ac-installation">AC installation</a>,
            <a href="/services/ac-maintenance">AC maintenance</a>, and
            <a href="/services/emergency-repair">emergency repair</a> across all service areas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTA
    heading="Need AC Repair in Buckeye, AZ? Call Now."
    subtext="Same-day service available. John Rigo at Altered Air — honest diagnosis, upfront pricing, reliable repairs."
  />

  <FAQ faqs={faqs} heading="AC Repair FAQs — Buckeye, AZ" />
</Layout>

<style>
  .steps-container { display: flex; flex-direction: column; gap: 0.25rem; }
  .step {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--gray-200);
  }
  .step:last-child { border-bottom: none; }
  .step-number {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--orange);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
  }
  .step-content h3 { margin-bottom: 0.3rem; font-size: 1rem; }
  .step-content p { color: var(--gray-600); font-size: 0.93rem; margin: 0; }
</style>
