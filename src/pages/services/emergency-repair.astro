---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import FAQ from '../../components/FAQ.astro';

const faqs = [
  {
    q: 'What counts as an HVAC or refrigeration emergency?',
    a: 'Any situation where health, safety, or significant financial loss is at risk. In summer, a complete AC failure in an occupied home — especially with elderly residents, children, or pets — is a medical emergency. For businesses, a refrigeration failure threatening perishable inventory or a cooling failure in a data center or medical facility qualifies as an emergency. When in doubt, call <a href="tel:+17605941125">(760) 594-1125</a> and we will help you assess the situation.'
  },
  {
    q: 'How fast can Altered Air respond to an emergency in Buckeye, AZ?',
    a: 'Our goal is to arrive within 2–4 hours of an emergency call, and often sooner depending on location and time of day. We are based in Buckeye, which puts us close to most West Valley communities. Emergency calls are always prioritized over scheduled maintenance appointments.'
  },
  {
    q: 'Does emergency service cost more?',
    a: 'Emergency and after-hours calls may carry an additional fee. We are always transparent about this upfront — you will know the cost before we dispatch. We believe that transparency during a stressful situation is what separates a trustworthy contractor from a price-gouging one.'
  },
  {
    q: 'What should I do while waiting for emergency AC repair?',
    a: 'If your AC fails in extreme heat: close blinds and curtains to block solar heat gain, move to the lowest floor of the home (heat rises), use battery-powered fans, drink plenty of water, and consider moving vulnerable family members to a cooled location like a library, mall, or neighbor\'s home while you wait. Do NOT let anyone remain in a home that is climbing above 90°F for extended periods.'
  },
  {
    q: 'Do you handle emergency commercial refrigeration service?',
    a: 'Yes. Commercial refrigeration emergencies are among our highest priorities. If your walk-in cooler, walk-in freezer, or commercial refrigeration system fails and you have perishable inventory at risk, call us immediately at <a href="tel:+17605941125">(760) 594-1125</a>. We serve restaurants, grocery stores, food processors, warehouses, and other commercial clients across the West Valley.'
  }
];
---

<Layout
  title="Emergency AC Repair Buckeye AZ — 24-Hour Service | Altered Air | (760) 594-1125"
  description="24-hour emergency AC repair and commercial refrigeration service in Buckeye, AZ. No AC in 115°F heat is a health emergency. Altered Air responds fast — call (760) 594-1125."
  canonical="/services/emergency-repair"
>
  <!-- Emergency Banner (always red on this page) -->
  <div class="emergency-banner">
    <div class="container">
      <strong>&#128680; 24/7 Emergency Line — Available Right Now.</strong>
      AC failure in Arizona heat is life-threatening. <a href="tel:+17605941125">Call (760) 594-1125 immediately.</a>
    </div>
  </div>

  <!-- Page Hero — red-tinted for emergency -->
  <section class="page-hero emergency-hero">
    <div class="container">
      <p class="breadcrumb"><a href="/">Home</a> → Services → Emergency Repair</p>
      <h1>Emergency AC Repair Buckeye AZ — 24-Hour Service</h1>
      <p>
        Altered Air is available 24 hours a day, 7 days a week, 365 days a year for emergency AC and
        commercial refrigeration repair in Buckeye, AZ and the West Valley. When you have no air conditioning
        in triple-digit heat, call John Rigo directly — we treat your emergency like our own.
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:1rem; margin-top:1.5rem;">
        <a href="tel:+17605941125" class="phone-link" style="background:#dc2626;">
          &#128680; CALL NOW: (760) 594-1125
        </a>
        <a href="/contact" class="btn-outline-white">Request Online</a>
      </div>
    </div>
  </section>

  <!-- Health warning section -->
  <section>
    <div class="container">
      <div class="content-two-col">
        <div>
          <h2>No AC in Arizona Summer Is a Medical Emergency</h2>
          <p>
            Maricopa County, which includes Buckeye and the entire West Valley, records more heat-related
            deaths each year than any other county in the United States. Between 2010 and 2020, Arizona
            averaged hundreds of heat-related deaths annually — with the vast majority occurring indoors,
            in homes where air conditioning had failed or was unavailable.
          </p>
          <p>
            When outdoor temperatures reach 115°F, indoor temperatures in a home without AC can climb
            above 100°F within hours. Heat stroke can occur when core body temperature exceeds 104°F,
            and it can be fatal — particularly in elderly adults, young children, and anyone with
            underlying health conditions.
          </p>
          <p>
            <strong>Do not wait until morning. Do not try to tough it out.</strong> If your AC has failed
            and temperatures are dangerous, call Altered Air at <a href="tel:+17605941125">(760) 594-1125</a>
            right now. We are awake. We are available. We will get there.
          </p>

          <h2 style="margin-top:2rem;">Emergency Refrigeration Failure</h2>
          <p>
            For commercial businesses, a refrigeration failure is both a financial and regulatory emergency.
            Walk-in cooler failures can destroy thousands of dollars in perishable inventory within hours.
            Health code violations apply if food is stored above safe temperatures. Equipment used in
            food processing, medical storage, or research can have even more severe consequences.
          </p>
          <p>
            Altered Air prioritizes commercial refrigeration emergency calls. We serve restaurants,
            grocery stores, <a href="/locations/tolleson-az">food processing facilities in Tolleson</a>,
            warehouse cold storage, and other commercial refrigeration clients throughout the West Valley.
          </p>
        </div>
        <div>
          <div class="emergency-call-box">
            <div class="emergency-badge">EMERGENCY LINE</div>
            <h3>Call John Rigo — Available Right Now</h3>
            <a href="tel:+17605941125" class="emergency-phone">(760) 594-1125</a>
            <p>Available 24 hours a day, 7 days a week<br />including holidays</p>
            <a href="tel:+17605941125" class="btn-emergency">Call Now — We'll Answer</a>
          </div>

          <div class="card" style="margin-top:1.5rem;">
            <h3>While You Wait for Arrival</h3>
            <ul class="feature-list">
              <li>Close all blinds and curtains immediately</li>
              <li>Move to the lowest floor (heat rises)</li>
              <li>Use any available fans to circulate air</li>
              <li>Drink water consistently — stay hydrated</li>
              <li>Move elderly, children &amp; pets to a cooled location</li>
              <li>Do not cook or use appliances that generate heat</li>
              <li>Place ice packs or wet towels on pulse points</li>
              <li>Call 911 if anyone shows signs of heat stroke</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Handle -->
  <section class="bg-gray">
    <div class="container">
      <h2>Emergency HVAC &amp; Refrigeration Situations We Handle</h2>
      <p style="max-width:680px; color:var(--gray-600); margin-bottom:2rem;">
        Altered Air responds to a wide range of emergency situations across residential, commercial,
        and industrial properties throughout the West Valley.
      </p>
      <div class="service-list">
        <div class="service-item">
          <h3>Complete AC System Failure</h3>
          <p>System not turning on, blown fuses, tripped breakers, failed compressor — we diagnose and repair all causes of total AC failure.</p>
        </div>
        <div class="service-item">
          <h3>AC Blowing Warm Air</h3>
          <p>Low refrigerant, a stuck reversing valve, or a failed compressor can all cause warm air output. We identify the cause fast and fix it right.</p>
        </div>
        <div class="service-item">
          <h3>Walk-in Cooler Emergency</h3>
          <p>Walk-in cooler not holding temperature, compressor failure, refrigerant leak, or door seal failure — every hour matters for your inventory.</p>
        </div>
        <div class="service-item">
          <h3>Walk-in Freezer Emergency</h3>
          <p>Freezer temperatures rising, frost buildup, defrost system failure, or complete shutdown — we respond to walk-in freezer emergencies 24/7.</p>
        </div>
        <div class="service-item">
          <h3>Commercial Refrigeration Failure</h3>
          <p>Reach-in refrigerators, deli cases, beverage coolers, ice machines, and other commercial units that fail during business hours or overnight.</p>
        </div>
        <div class="service-item">
          <h3>AC Making Dangerous Noises</h3>
          <p>Grinding, banging, or screeching sounds indicate mechanical failure that could destroy the system. Emergency diagnosis prevents a small repair from becoming a full replacement.</p>
        </div>
        <div class="service-item">
          <h3>Refrigerant Leak Emergency</h3>
          <p>Refrigerant leaks reduce cooling capacity and can be hazardous. We locate leaks, make EPA-compliant repairs, and recharge your system.</p>
        </div>
        <div class="service-item">
          <h3>Heating Emergency (Winter)</h3>
          <p>Furnace or heat pump failure on a cold winter night. We also handle heating emergencies to keep your family or business warm when temperatures drop.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section>
    <div class="container">
      <h2>24/7 Emergency Service Area — West Valley, AZ</h2>
      <p style="max-width:680px; color:var(--gray-600); margin-bottom:1.5rem;">
        Our emergency AC and refrigeration service covers the entire West Valley metro area.
        Based in Buckeye, we typically reach most locations within 30–60 minutes.
      </p>
      <div class="location-grid">
        <div class="location-tag"><a href="/locations/buckeye-az">Buckeye</a></div>
        <div class="location-tag"><a href="/locations/goodyear-az">Goodyear</a></div>
        <div class="location-tag"><a href="/locations/queen-creek-az">Queen Creek</a></div>
        <div class="location-tag"><a href="/locations/surprise-az">Surprise</a></div>
        <div class="location-tag"><a href="/locations/avondale-az">Avondale</a></div>
        <div class="location-tag"><a href="/locations/litchfield-park-az">Litchfield Park</a></div>
        <div class="location-tag"><a href="/locations/tolleson-az">Tolleson</a></div>
        <div class="location-tag"><a href="/locations/laveen-az">Laveen</a></div>
        <div class="location-tag"><a href="/locations/peoria-az">Peoria</a></div>
      </div>
      <p style="margin-top:1.25rem; font-size:0.9rem; color:var(--gray-600);">
        Not sure if we cover your area? Call <a href="tel:+17605941125">(760) 594-1125</a> and we
        will confirm availability instantly. Also see: <a href="/services/ac-repair">AC repair</a>,
        <a href="/services/refrigeration-repair">refrigeration repair</a>, and
        <a href="/services/heating">heating service</a>.
      </p>
    </div>
  </section>

  <CTA
    heading="HVAC Emergency? Call Altered Air Right Now."
    subtext="John Rigo is available 24/7 for emergency AC repair and commercial refrigeration service throughout Buckeye, AZ and the West Valley. No AC in Arizona heat is not something to wait on."
    emergency={true}
  />

  <FAQ faqs={faqs} heading="Emergency HVAC Service FAQs" />
</Layout>

<style>
  .emergency-hero {
    background: linear-gradient(135deg, #450a0a, #7f1d1d, #991b1b) !important;
  }
  .emergency-call-box {
    background: linear-gradient(135deg, #7f1d1d, #b91c1c);
    color: white;
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
  }
  .emergency-badge {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    color: #fca5a5;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    margin-bottom: 0.875rem;
  }
  .emergency-call-box h3 {
    color: white;
    margin-bottom: 0.875rem;
    font-size: 1.2rem;
  }
  .emergency-phone {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: #fbbf24;
    text-decoration: none;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }
  .emergency-phone:hover { text-decoration: underline; }
  .emergency-call-box p {
    color: rgba(255,255,255,0.8);
    font-size: 0.88rem;
    margin-bottom: 1.25rem;
    line-height: 1.5;
  }
  .btn-emergency {
    display: inline-block;
    background: #fbbf24;
    color: #7f1d1d !important;
    padding: 0.875rem 1.75rem;
    border-radius: 6px;
    font-weight: 800;
    font-size: 1rem;
    text-decoration: none !important;
    transition: background 0.2s;
  }
  .btn-emergency:hover { background: #f59e0b; }
</style>
