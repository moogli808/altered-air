---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import FAQ from '../../components/FAQ.astro';

const faqs = [
  {
    q: 'How do I know what size AC unit I need for my home or business?',
    a: 'Sizing an AC system requires a Manual J load calculation that accounts for your square footage, ceiling height, insulation levels, window placement, occupancy, and local climate data. In Buckeye and the West Valley, homes are often undersized by contractors who do not account for extreme Arizona heat. John Rigo performs proper load calculations before recommending any system — never just matching the old unit size.'
  },
  {
    q: 'How long does an AC installation take?',
    a: 'A standard residential AC replacement typically takes 4–8 hours for a single system. New construction or ductwork modifications take longer. Commercial installations vary widely based on system complexity. We give you a realistic time estimate before we start so you can plan accordingly.'
  },
  {
    q: 'What is the best AC system for Arizona heat?',
    a: 'For the extreme Arizona climate, we typically recommend high-efficiency systems (16 SEER or higher) with a proven track record in desert environments. Carrier, Trane, and Lennox all have strong performers in high-heat climates. Mini-split systems from Daikin or Mitsubishi are excellent for zoned cooling and room additions. We will walk you through the options that make the most sense for your situation and budget.'
  },
  {
    q: 'Do you install mini-split and ductless AC systems?',
    a: 'Yes. Mini-split and ductless systems are increasingly popular in Arizona, especially for garage cooling, room additions, casitas, and commercial spaces that lack existing ductwork. We install systems from Daikin, Mitsubishi, LG, and other leading mini-split brands.'
  },
  {
    q: 'What financing options are available for new AC installations?',
    a: 'We work with customers to make new AC installations affordable. Ask us about available financing options and manufacturer rebates when you call for your free quote at <a href="tel:+17605941125">(760) 594-1125</a>.'
  }
];
---

<Layout
  title="AC Installation in Buckeye, AZ | Altered Air | (760) 594-1125"
  description="New AC installation in Buckeye, AZ and across the West Valley. Central AC, mini splits, heat pumps, packaged units. Free quotes from John Rigo at Altered Air. Call (760) 594-1125."
  canonical="/services/ac-installation"
>
  <section class="page-hero">
    <div class="container">
      <p class="breadcrumb"><a href="/">Home</a> → Services → AC Installation</p>
      <h1>AC Installation in Buckeye, AZ — West Valley</h1>
      <p>
        Installing the right AC system for a West Valley home or business requires more than matching
        a unit to a square footage number. John Rigo at Altered Air performs proper load calculations,
        recommends the most efficient systems for Arizona's extreme climate, and installs every unit with
        precision and care.
      </p>
      <a href="tel:+17605941125" class="phone-link">&#128222; Free Quote: (760) 594-1125</a>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="content-two-col">
        <div>
          <h2>AC Systems We Install</h2>
          <p>
            Altered Air installs the full range of residential and commercial air conditioning systems.
            Whether you are replacing an aging unit, building a new home in <a href="/locations/buckeye-az">Buckeye's expanding developments</a>,
            outfitting a commercial property, or adding cooling to a garage or room addition — we have
            the system and the expertise to do it right.
          </p>

          <div class="service-list" style="margin-top:1.5rem;">
            <div class="service-item">
              <h3>Central Air Conditioning</h3>
              <p>Standard forced-air central AC systems for homes and commercial buildings. We install split systems with matched indoor and outdoor components for maximum efficiency.</p>
            </div>
            <div class="service-item">
              <h3>Mini-Split &amp; Ductless Systems</h3>
              <p>Ideal for garages, room additions, casitas, and spaces without existing ductwork. Wall-mounted or ceiling cassette units provide precise zoned cooling without duct losses.</p>
            </div>
            <div class="service-item">
              <h3>Packaged AC Units</h3>
              <p>All-in-one packaged units are common in Arizona commercial buildings and some residential applications. We install and configure all major packaged unit styles.</p>
            </div>
            <div class="service-item">
              <h3>Heat Pumps</h3>
              <p>Heat pumps provide both heating and cooling from a single system. With Arizona's mild winters and hot summers, a high-efficiency heat pump can be an excellent investment.</p>
            </div>
            <div class="service-item">
              <h3>Zoned HVAC Systems</h3>
              <p>Multi-zone systems with independent thermostats for different areas of a home or building. Stop cooling empty rooms and pay only for comfort where you need it.</p>
            </div>
            <div class="service-item">
              <h3>Smart Thermostats</h3>
              <p>We install and configure Nest, Ecobee, Honeywell, and other smart thermostats. Proper programming and setup reduces energy waste and extends equipment life.</p>
            </div>
          </div>
        </div>
        <div>
          <div class="highlight-box">
            <h3>Free Installation Quote</h3>
            <p>
              John Rigo provides free, no-pressure quotes on all new AC installations. Get honest
              recommendations and upfront pricing before committing to anything.
            </p>
            <a href="tel:+17605941125" class="phone">(760) 594-1125</a>
            <a href="/contact" class="btn-primary" style="margin-top:0.5rem;">Request a Quote</a>
          </div>
          <div class="card" style="margin-top:1.5rem;">
            <h3>Why Proper Sizing Matters in Arizona</h3>
            <p>
              An undersized AC unit in Buckeye will run constantly, fail prematurely, and never keep
              your home comfortable on 115°F days. An oversized unit short-cycles, leaving humidity
              high and wearing out components faster. John performs a proper Manual J load calculation
              on every installation to get the sizing exactly right.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray">
    <div class="container">
      <h2>The Altered Air Installation Process</h2>
      <p style="max-width:680px; color:var(--gray-600); margin-bottom:2.5rem;">
        Every installation follows the same thorough process — from initial assessment through
        final testing and walkthrough.
      </p>
      <div style="max-width:760px;">
        <div class="install-step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>On-Site Assessment &amp; Load Calculation</h3>
            <p>John visits your property, measures the space, evaluates insulation and windows, and performs a Manual J calculation to determine the right system capacity.</p>
          </div>
        </div>
        <div class="install-step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3>System Recommendation &amp; Quote</h3>
            <p>We present you with a written quote that includes equipment specifications, efficiency ratings, and total installed cost. No upselling. No pressure.</p>
          </div>
        </div>
        <div class="install-step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3>Professional Installation</h3>
            <p>Our team installs your system according to manufacturer specifications and all applicable codes. We handle all refrigerant work with EPA-certified procedures.</p>
          </div>
        </div>
        <div class="install-step">
          <div class="step-number">4</div>
          <div class="step-content">
            <h3>System Commissioning &amp; Testing</h3>
            <p>We fully charge and test the system, verify correct airflow, check refrigerant pressures, and confirm the system is performing to specification before we leave.</p>
          </div>
        </div>
        <div class="install-step">
          <div class="step-number">5</div>
          <div class="step-content">
            <h3>Walkthrough &amp; Warranty Registration</h3>
            <p>We walk you through operation, filter maintenance, and thermostat programming. We register your equipment warranty and provide all documentation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2>Brands We Install</h2>
      <p style="max-width:680px; color:var(--gray-600); margin-bottom:1.5rem;">
        We are not locked into a single brand. John recommends systems based on reliability,
        efficiency, and value for your specific application and budget.
      </p>
      <ul class="feature-list" style="max-width:560px;">
        <li>Carrier &amp; Bryant — industry-leading reliability</li>
        <li>Trane &amp; American Standard — built for durability</li>
        <li>Lennox — top efficiency ratings</li>
        <li>Daikin &amp; Mitsubishi Electric — mini-split specialists</li>
        <li>Rheem &amp; Ruud — strong value</li>
        <li>Goodman &amp; Amana — budget-friendly options</li>
        <li>LG — advanced multi-zone systems</li>
      </ul>
      <p style="margin-top:1.5rem; font-size:0.9rem; color:var(--gray-600);">
        Also see: <a href="/services/ac-repair">AC repair</a>, <a href="/services/ac-maintenance">AC maintenance</a>,
        and <a href="/services/emergency-repair">emergency AC service</a> across
        <a href="/locations/buckeye-az">Buckeye</a>, <a href="/locations/goodyear-az">Goodyear</a>,
        and the West Valley.
      </p>
    </div>
  </section>

  <CTA
    heading="Get a Free AC Installation Quote in Buckeye, AZ"
    subtext="John Rigo at Altered Air provides honest, no-pressure equipment recommendations and upfront pricing on all new AC installations across the West Valley."
  />

  <FAQ faqs={faqs} heading="AC Installation FAQs — West Valley, AZ" />
</Layout>

<style>
  .install-step {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--gray-200);
  }
  .install-step:last-child { border-bottom: none; }
  .step-number {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--orange);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
  }
  .step-content h3 { margin-bottom: 0.3rem; font-size: 1rem; }
  .step-content p { color: var(--gray-600); font-size: 0.93rem; margin: 0; }
</style>
