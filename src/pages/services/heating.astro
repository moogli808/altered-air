---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import FAQ from '../../components/FAQ.astro';

const faqs = [
  {
    q: 'Does Buckeye, AZ actually get cold enough to need a heater?',
    a: 'Yes. While Arizona winters are mild by national standards, Buckeye and the West Valley regularly see overnight lows in the 30s and 40s from December through February, with occasional near-freezing temperatures. Businesses and homes need functional heating, and cold snaps can be hard on aging or poorly maintained heating systems. A furnace or heat pump that fails on a cold night is a genuine discomfort — and for elderly residents, a health concern.'
  },
  {
    q: 'Is a heat pump or a furnace better for Arizona homes?',
    a: 'In Arizona, heat pumps are often an excellent choice because they provide both heating and cooling from a single system. They work most efficiently in the moderate temperature swings of an Arizona winter (typically above 30–35°F). For very cold nights or energy backup, a dual-fuel system (heat pump plus gas furnace) gives you the best of both worlds. John Rigo can evaluate your situation and recommend the right approach for your home and budget.'
  },
  {
    q: 'Do you repair gas furnaces?',
    a: 'Yes. We repair both gas and electric furnaces of all major brands. Gas furnace repairs include igniter replacement, heat exchanger inspection, gas valve repair, blower motor repair, and control board replacement. If you smell gas near your furnace, leave the building and call your gas company before calling us.'
  },
  {
    q: 'How do I know if my heating system needs service?',
    a: 'Common signs include: heating system not reaching set temperature, unusual noises when running (banging, rattling, squealing), uneven heating across the building, higher than usual gas or electric bills, pilot light repeatedly going out, or the system cycling on and off frequently. If your heating system is over 15 years old, regular inspection is especially important.'
  },
  {
    q: 'Can you install a smart thermostat with my heating system?',
    a: 'Yes. Smart thermostat installation and configuration is part of our heating services. A properly programmed Nest, Ecobee, or Honeywell smart thermostat can reduce heating (and cooling) costs by 10–15% through better scheduling and setbacks. We handle installation and make sure you know how to use it.'
  }
];
---

<Layout
  title="Heating Repair & Installation in Buckeye, AZ | Altered Air | (760) 594-1125"
  description="Furnace repair, heat pump installation, and heating service in Buckeye, AZ. Emergency heating repair available. John Rigo at Altered Air — call (760) 594-1125."
  canonical="/services/heating"
>
  <section class="page-hero">
    <div class="container">
      <p class="breadcrumb"><a href="/">Home</a> → Services → Heating</p>
      <h1>Heating Repair &amp; Installation — Buckeye, AZ</h1>
      <p>
        Arizona winters are mild, but they are real — and a heating system that fails on a cold night
        is never convenient. Altered Air provides furnace repair and installation, heat pump service,
        and emergency heating repair throughout Buckeye and the West Valley.
      </p>
      <a href="tel:+17605941125" class="phone-link">&#128222; Call (760) 594-1125</a>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="content-two-col">
        <div>
          <h2>Heating Services We Provide</h2>
          <p>
            Altered Air offers a complete range of heating services for residential and commercial
            properties throughout Buckeye and the West Valley. Whether you need a furnace repaired,
            a heat pump installed, or a smart thermostat programmed, John Rigo handles it with the
            same attention to quality and honest pricing that defines all of our work.
          </p>

          <div class="service-list" style="margin-top:1.5rem;">
            <div class="service-item">
              <h3>Gas Furnace Repair</h3>
              <p>Repair of all gas furnace components — igniters, heat exchangers, gas valves, blower motors, control boards, and more. We service all major brands.</p>
            </div>
            <div class="service-item">
              <h3>Electric Furnace Repair</h3>
              <p>Electric furnace diagnostics and repair including heating elements, sequencers, contactors, and blower assemblies.</p>
            </div>
            <div class="service-item">
              <h3>Furnace Installation</h3>
              <p>New gas and electric furnace installation for homes and commercial properties. Proper sizing, venting, and fuel connection for safe, efficient operation.</p>
            </div>
            <div class="service-item">
              <h3>Heat Pump Installation</h3>
              <p>Heat pump systems that provide both heating and cooling from a single unit. Excellent efficiency for Arizona's climate with its moderate winters and extreme summers.</p>
            </div>
            <div class="service-item">
              <h3>Heat Pump Repair</h3>
              <p>Reversing valve repair, refrigerant recharge, compressor and coil repair, and defrost system service for heat pumps of all major brands.</p>
            </div>
            <div class="service-item">
              <h3>Emergency Heating Repair</h3>
              <p>No heat on a cold Arizona night? We offer emergency heating service throughout Buckeye and the West Valley. Call <a href="tel:+17605941125">(760) 594-1125</a>.</p>
            </div>
            <div class="service-item">
              <h3>Heating Maintenance</h3>
              <p>Pre-season heating tune-ups to verify safe and efficient operation before temperatures drop. Includes heat exchanger inspection, burner cleaning, and system performance test.</p>
            </div>
            <div class="service-item">
              <h3>Smart Thermostat Installation</h3>
              <p>Installation and configuration of Nest, Ecobee, Honeywell, and other smart thermostats. Proper setup with your heating and cooling system for maximum efficiency.</p>
            </div>
          </div>
        </div>
        <div>
          <div class="highlight-box">
            <h3>Heat Not Working?</h3>
            <p>
              Emergency heating service available throughout Buckeye and the West Valley.
              Call John Rigo — available day and night.
            </p>
            <a href="tel:+17605941125" class="phone">(760) 594-1125</a>
            <a href="tel:+17605941125" class="btn-primary" style="margin-top:0.5rem;">Call Now</a>
          </div>
          <div class="card" style="margin-top:1.5rem;">
            <h3>Heat Pump vs. Furnace in Arizona</h3>
            <p>
              Arizona winters are ideal for heat pump efficiency — the outdoor temperatures rarely
              drop into the range where heat pumps lose effectiveness. A properly sized heat pump
              can heat your home efficiently all winter and cool it all summer from a single system.
            </p>
            <p>
              John Rigo will give you an honest comparison of heat pump vs. furnace costs and
              performance for your specific situation — no sales pitch, just real information.
            </p>
            <a href="/contact" class="card-link">Get a Free Consultation →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray">
    <div class="container">
      <h2>Signs Your Heating System Needs Service</h2>
      <p style="max-width:680px; color:var(--gray-600); margin-bottom:1.5rem;">
        Because Arizona winters are short, heating problems are easy to miss until the system is
        actually called on to perform. Watch for these warning signs — especially before temperatures
        start dropping in November.
      </p>
      <ul class="feature-list" style="max-width:680px;">
        <li>System runs but home does not reach set temperature</li>
        <li>Unusual noises — banging, rattling, or squealing on startup</li>
        <li>Yellow or flickering furnace pilot light (should be blue)</li>
        <li>Gas smell near the furnace — leave and call immediately</li>
        <li>System short-cycles or runs continuously</li>
        <li>Uneven heating across rooms</li>
        <li>Higher than expected gas or electric bills</li>
        <li>System is over 15 years old with no recent service</li>
        <li>Heat pump blowing cool air in heating mode</li>
      </ul>
      <p style="margin-top:1.5rem; font-size:0.9rem; color:var(--gray-600);">
        Also see our <a href="/services/ac-repair">AC repair</a>, <a href="/services/ac-installation">AC installation</a>,
        and <a href="/services/emergency-repair">emergency repair</a> services.
        We serve <a href="/locations/buckeye-az">Buckeye</a>, <a href="/locations/goodyear-az">Goodyear</a>,
        <a href="/locations/surprise-az">Surprise</a>, and all West Valley communities.
      </p>
    </div>
  </section>

  <CTA
    heading="Heating Problem in Buckeye, AZ? Call Now."
    subtext="John Rigo at Altered Air provides furnace repair, heat pump service, and emergency heating repair throughout Buckeye and the entire West Valley."
  />

  <FAQ faqs={faqs} heading="Heating Service FAQs — Buckeye, AZ" />
</Layout>
