---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import FAQ from '../components/FAQ.astro';

const faqs = [
  {
    q: 'Who is John Rigo?',
    a: 'John Rigo is the owner and lead technician at Altered Air. He is based in Buckeye, AZ and personally handles service calls, project consultations, and quality oversight on every job Altered Air takes. When you call Altered Air, you are talking to John — and John is the one who shows up.'
  },
  {
    q: 'Is Altered Air licensed and insured?',
    a: 'Altered Air carries general liability insurance and is currently in the process of obtaining its contractor license. We operate with full transparency about our licensing status and hold ourselves to a licensed contractor\'s standards of quality, safety, and professionalism on every job.'
  },
  {
    q: 'How long has Altered Air been in business?',
    a: 'Altered Air is a newer business built on real experience. John Rigo brings years of hands-on experience in commercial refrigeration design and installation, residential and commercial AC, and heating systems. Altered Air was founded to bring that expertise directly to the West Valley under a business model built on honesty and accountability.'
  },
  {
    q: 'Does Altered Air work on weekends and holidays?',
    a: 'Yes. We offer 24/7 emergency service, 365 days a year — including weekends, holidays, and nights. John Rigo understands that AC failures and refrigeration emergencies do not observe business hours. Call <a href="tel:+17605941125">(760) 594-1125</a> any time.'
  },
  {
    q: 'How does Altered Air approach pricing?',
    a: 'Honestly and transparently. We give you a written estimate before any work begins, explain what we found and what needs to be done in plain language, and stick to our quoted price. We do not upsell services you do not need, and we do not surprise you with charges after the work is done.'
  }
];
---

<Layout
  title="About Altered Air — John Rigo, Buckeye AZ | (760) 594-1125"
  description="Altered Air is Buckeye, AZ's locally owned commercial refrigeration and AC company. Owner John Rigo — honest service, transparent pricing, West Valley locals serving West Valley locals."
  canonical="/about"
>
  <section class="page-hero">
    <div class="container">
      <p class="breadcrumb"><a href="/">Home</a> → About</p>
      <h1>About Altered Air — Buckeye, AZ</h1>
      <p>
        Altered Air is a locally owned HVAC and commercial refrigeration company based in Buckeye, AZ.
        Founded by John Rigo, we serve the West Valley with the technical expertise of a large contractor
        and the personal accountability that only a small, owner-operated business can deliver.
      </p>
      <a href="tel:+17605941125" class="phone-link">&#128222; (760) 594-1125</a>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="content-two-col">
        <div>
          <h2>John Rigo — Owner &amp; Lead Technician</h2>
          <p>
            John Rigo is not a salesperson, a dispatcher, or a corporate manager. He is the person
            who answers the phone when you call Altered Air, the person who shows up at your door,
            and the person who does the work. That direct accountability is central to everything
            Altered Air does.
          </p>
          <p>
            John brings deep hands-on experience across the full range of HVAC and commercial
            refrigeration services — from complex walk-in cooler design and installation to
            residential AC replacement, mini-split systems, furnace service, and emergency repairs.
            He has worked on systems ranging from residential split units to large commercial
            refrigeration systems for food processing facilities.
          </p>
          <p>
            More than technical expertise, John brings a commitment to honesty that is increasingly
            rare in the trades. He will tell you when a repair is worth making and when it is not.
            He will give you a real quote — not a low-ball number that doubles once he is inside your
            home. He will show up when he says he will. And if something is not right, he will
            come back and fix it.
          </p>
          <p>
            John founded Altered Air in Buckeye because he saw a real need: a rapidly growing West
            Valley market with residential and commercial HVAC and refrigeration needs that were
            underserved by local contractors with the right expertise. Altered Air fills that gap.
          </p>

          <h2 style="margin-top:2rem;">West Valley Locals Serving West Valley Locals</h2>
          <p>
            Altered Air is not a franchise, a call center, or a company that dispatches subcontractors.
            It is John Rigo and a team built around the same values — honest work, real expertise, and
            genuine care about the communities we serve.
          </p>
          <p>
            Buckeye is growing faster than any other large city in America. The West Valley is one of
            the most economically dynamic regions in the country. We are proud to be part of that
            growth — and committed to growing with the community we serve, not just extracting value
            from it.
          </p>
        </div>
        <div>
          <div class="highlight-box">
            <h3>Altered Air at a Glance</h3>
            <p>Commercial refrigeration and AC specialist, based in Buckeye, AZ.</p>
            <a href="tel:+17605941125" class="phone">(760) 594-1125</a>
            <a href="tel:+17605941125" class="btn-primary" style="margin-top:0.5rem;">Call John Directly</a>
          </div>

          <div class="card" style="margin-top:1.5rem;">
            <h3>Our Commitment</h3>
            <ul class="feature-list">
              <li>Honest, upfront pricing — no surprises</li>
              <li>Show up when we say we will</li>
              <li>Diagnose accurately the first time</li>
              <li>Recommend what you actually need</li>
              <li>Stand behind every job we do</li>
              <li>24/7 availability for real emergencies</li>
              <li>Commercial refrigeration expertise — not just HVAC</li>
            </ul>
          </div>

          <div class="card" style="margin-top:1rem;">
            <h3>Contact &amp; Location</h3>
            <address class="nap-block" style="font-size:0.9rem; line-height:1.9;">
              <strong>Altered Air</strong><br />
              1009 E Narramore Ave<br />
              Buckeye, AZ 85326<br />
              <a href="tel:+17605941125">(760) 594-1125</a><br />
              Owner: John Rigo<br />
              Contractor License: Pending
            </address>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray">
    <div class="container">
      <h2>Services We Provide</h2>
      <p style="max-width:680px; color:var(--gray-600); margin-bottom:2rem;">
        Altered Air covers the full range of residential and commercial HVAC and refrigeration services
        across the West Valley.
      </p>
      <div class="grid-3">
        <div class="card">
          <h3>Air Conditioning</h3>
          <p>AC repair, installation, and maintenance for homes and commercial properties. Same-day service. <a href="/services/ac-repair">Learn more →</a></p>
        </div>
        <div class="card">
          <h3>Commercial Refrigeration</h3>
          <p>Walk-in cooler and freezer repair, installation, design, and maintenance. 24/7 emergency response. <a href="/services/refrigeration-repair">Learn more →</a></p>
        </div>
        <div class="card">
          <h3>Emergency Repair</h3>
          <p>24-hour emergency AC and refrigeration service. No AC in Phoenix heat or refrigeration failure in food service cannot wait. <a href="/services/emergency-repair">Learn more →</a></p>
        </div>
        <div class="card">
          <h3>Heating</h3>
          <p>Furnace repair, heat pump service, and heating installation for West Valley homes and businesses. <a href="/services/heating">Learn more →</a></p>
        </div>
        <div class="card">
          <h3>AC Installation</h3>
          <p>New system installation with proper sizing and commissioning for Arizona's extreme climate. <a href="/services/ac-installation">Learn more →</a></p>
        </div>
        <div class="card">
          <h3>Refrigeration Design</h3>
          <p>Custom commercial refrigeration system design for new builds, restaurant renovations, and industrial applications. <a href="/services/refrigeration-design">Learn more →</a></p>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2>Our Service Area</h2>
      <p style="max-width:680px; color:var(--gray-600); margin-bottom:1.5rem;">
        Based in Buckeye, Altered Air serves all of the West Valley and surrounding Phoenix metro area.
      </p>
      <div class="location-grid">
        <div class="location-tag"><a href="/locations/buckeye-az">Buckeye</a></div>
        <div class="location-tag"><a href="/locations/goodyear-az">Goodyear</a></div>
        <div class="location-tag"><a href="/locations/queen-creek-az">Queen Creek</a></div>
        <div class="location-tag"><a href="/locations/surprise-az">Surprise</a></div>
        <div class="location-tag"><a href="/locations/avondale-az">Avondale</a></div>
        <div class="location-tag"><a href="/locations/litchfield-park-az">Litchfield Park</a></div>
        <div class="location-tag"><a href="/locations/tolleson-az">Tolleson</a></div>
        <div class="location-tag"><a href="/locations/laveen-az">Laveen</a></div>
        <div class="location-tag"><a href="/locations/peoria-az">Peoria</a></div>
      </div>
    </div>
  </section>

  <CTA
    heading="Get to Know Us — Or Just Call"
    subtext="John Rigo at Altered Air is always happy to discuss your HVAC or refrigeration needs. No pressure, no obligation. Just honest conversation and real answers."
  />

  <FAQ faqs={faqs} heading="About Altered Air — Common Questions" />
</Layout>
