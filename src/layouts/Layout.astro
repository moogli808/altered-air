---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
}

const { title, description, canonical, ogTitle, ogDescription } = Astro.props;
const siteUrl = 'https://www.alteredairinc.com';
const fullCanonical = `${siteUrl}${canonical}`;
const ogTitleFinal = ogTitle ?? title;
const ogDescFinal = ogDescription ?? description;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["HVACBusiness", "LocalBusiness"],
  "name": "Altered Air",
  "description": "Commercial refrigeration and AC repair serving Buckeye, AZ and the West Valley. Owner and lead technician: John Rigo.",
  "url": siteUrl,
  "telephone": "+17605941125",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "1009 E Narramore Ave",
    "addressLocality": "Buckeye",
    "addressRegion": "AZ",
    "postalCode": "85326",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 33.3706,
    "longitude": -112.5837
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "00:00",
    "closes": "23:59"
  },
  "priceRange": "$$",
  "areaServed": [
    {"@type": "City", "name": "Buckeye", "addressRegion": "AZ"},
    {"@type": "City", "name": "Goodyear", "addressRegion": "AZ"},
    {"@type": "City", "name": "Queen Creek", "addressRegion": "AZ"},
    {"@type": "City", "name": "Surprise", "addressRegion": "AZ"},
    {"@type": "City", "name": "Avondale", "addressRegion": "AZ"},
    {"@type": "City", "name": "Litchfield Park", "addressRegion": "AZ"},
    {"@type": "City", "name": "Tolleson", "addressRegion": "AZ"},
    {"@type": "City", "name": "Laveen", "addressRegion": "AZ"},
    {"@type": "City", "name": "Peoria", "addressRegion": "AZ"}
  ],
  "founder": {
    "@type": "Person",
    "name": "John Rigo"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "HVAC & Refrigeration Services",
    "itemListElement": [
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "AC Repair"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "AC Installation"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "AC Maintenance"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Emergency 24-Hour AC Repair"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Commercial Refrigeration Repair"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Walk-in Cooler Repair"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Walk-in Freezer Repair"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Refrigeration Installation"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Heating Repair"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Furnace Installation"}}
    ]
  }
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullCanonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={ogTitleFinal} />
  <meta property="og:description" content={ogDescFinal} />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Altered Air" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={ogTitleFinal} />
  <meta name="twitter:description" content={ogDescFinal} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <!-- Schema -->
  <script type="application/ld+json" set:html={schema} />

  <!-- Critical above-fold CSS inlined to eliminate render-blocking for first paint -->
  <style is:global>
    :root{--navy:#0d2137;--navy-dark:#071524;--navy-light:#1a3a5c;--orange:#f97316;--orange-dark:#ea580c;--white:#ffffff;--gray-50:#f9fafb;--gray-100:#f3f4f6;--gray-200:#e5e7eb;--gray-500:#6b7280;--gray-600:#4b5563;--gray-700:#374151;--gray-900:#111827;--text:#1f2937;--font:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Oxygen,Ubuntu,Cantarell,sans-serif}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:var(--font);color:var(--text);line-height:1.7;background:var(--white);font-size:1rem}
    h1,h2,h3,h4,h5{line-height:1.25;color:var(--navy);font-weight:700}
    h1{font-size:clamp(1.75rem,4vw,2.75rem)}
    h2{font-size:clamp(1.4rem,3vw,2rem)}
    h3{font-size:clamp(1.1rem,2.5vw,1.4rem)}
    p{margin-bottom:1rem}
    p:last-child{margin-bottom:0}
    a{color:var(--orange);text-decoration:none}
    a:hover{text-decoration:underline}
    img{max-width:100%;height:auto;display:block}
    .container{max-width:1200px;margin:0 auto;padding:0 1.25rem}
    section{padding:4rem 0}
    .btn-primary{display:inline-block;background:var(--orange);color:var(--white)!important;padding:.875rem 1.75rem;border-radius:6px;font-weight:700;font-size:1rem;text-decoration:none!important;transition:background .2s,transform .1s;border:none;cursor:pointer;line-height:1.2}
    .btn-primary:hover{background:var(--orange-dark);transform:translateY(-1px)}
    .emergency-banner{background:#dc2626;color:var(--white);padding:.875rem 0;text-align:center;font-size:.95rem}
    .emergency-banner a{color:var(--white);font-weight:700;text-decoration:underline}
    .hero{background:linear-gradient(135deg,var(--navy-dark) 0%,var(--navy) 60%,var(--navy-light) 100%);color:var(--white);padding:5rem 0 4rem}
    .hero h1{color:var(--white);margin-bottom:1.25rem}
    .page-hero{background:linear-gradient(135deg,var(--navy-dark) 0%,var(--navy) 100%);color:var(--white);padding:3.5rem 0 3rem}
    .page-hero h1{color:var(--white);margin-bottom:1rem}
    .page-hero .breadcrumb{font-size:.85rem;color:rgba(255,255,255,.65);margin-bottom:1rem}
    .page-hero .breadcrumb a{color:rgba(255,255,255,.8)}
    .page-hero p{color:rgba(255,255,255,.9);font-size:1.05rem;max-width:620px;margin-bottom:1.5rem}
    .page-hero .phone-link{display:inline-flex;align-items:center;gap:.5rem;background:var(--orange);color:var(--white)!important;padding:.75rem 1.5rem;border-radius:6px;font-weight:700;font-size:1.1rem;text-decoration:none!important}
    .page-hero .phone-link:hover{background:var(--orange-dark)}
  </style>
</head>
<body>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</body>
</html>
